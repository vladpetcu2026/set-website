---
import Monogram from './Monogram.astro';
import type { Messages } from '../i18n/ro';

interface Props {
  t: Messages;
}

const { t } = Astro.props;

// Pe paginile non-home, ancorele trebuie sa pointeze inapoi la home + anchor.
const pathname = Astro.url.pathname;
const isEN = pathname.startsWith('/en');
const homeHref = isEN ? '/en/' : '/';
const isHome = pathname === '/' || pathname === '/en/' || pathname === '/en';
const a = (anchor: string) => (isHome ? `#${anchor}` : `${homeHref}#${anchor}`);
---

<header class="set-nav">
  <div class="set-nav__inner">
    <a class="set-nav__brand" href={homeHref}>
      <Monogram size="xs" color="yellow" />
      <span class="set-nav__brand-name">sustainable edtech romania</span>
    </a>

    <nav class="set-nav__menu" aria-label="primary">
      <a href={a('servicii')}>{t.nav.services}</a>
      <a href={a('proces')}>{t.nav.process}</a>
      <a href={a('cazuri')}>{t.nav.cases}</a>
      <a href={a('despre')}>{t.nav.about}</a>
      <a href={a('contact')}>{t.nav.contact}</a>
    </nav>

    <div class="set-nav__right">
      <a class="set-nav__lang" href={t.langSwitcher.otherHref} aria-label={`Switch to ${t.langSwitcher.other}`}>
        <span class="set-nav__lang-current">{t.langSwitcher.current}</span>
        <span class="set-nav__lang-sep">·</span>
        <span class="set-nav__lang-other">{t.langSwitcher.other}</span>
      </a>
      <a class="set-btn set-btn--brand" href={a('contact')}>{t.nav.ctaButton}</a>
    </div>
  </div>
</header>

<style>
  .set-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--set-black);
    color: var(--set-white);
    border-bottom: 1.5px solid var(--set-black);
  }
  .set-nav__inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 20px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  .set-nav__brand {
    display: flex;
    align-items: center;
    gap: 16px;
    color: inherit;
    text-decoration: none;
  }
  .set-nav__brand-name {
    font-size: 13px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    opacity: 0.75;
  }
  .set-nav__menu {
    display: flex;
    gap: 28px;
    font-size: 13px;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .set-nav__menu a {
    color: var(--set-white);
    opacity: 0.75;
    text-decoration: none;
    transition: opacity 0.12s, color 0.12s;
  }
  .set-nav__menu a:hover {
    opacity: 1;
    color: var(--set-yellow);
  }
  .set-nav__right {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .set-nav__lang {
    font-size: 12px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--set-white);
    opacity: 0.75;
    text-decoration: none;
    display: inline-flex;
    gap: 6px;
    align-items: baseline;
  }
  .set-nav__lang:hover { opacity: 1; }
  .set-nav__lang-current { color: var(--set-yellow); font-weight: 600; }
  .set-nav__lang-sep { opacity: 0.5; }

  @media (max-width: 900px) {
    .set-nav__brand-name,
    .set-nav__menu { display: none; }
    .set-nav__inner { padding: 16px 20px; gap: 12px; }
  }
  @media (max-width: 480px) {
    .set-nav__inner { padding: 12px 16px; }
    .set-nav__right { gap: 12px; }
    .set-nav__right :global(.set-btn) { padding: 10px 12px; font-size: 12px; }
  }
</style>
