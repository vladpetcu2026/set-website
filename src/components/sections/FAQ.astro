---
import type { Messages } from '../../i18n/ro';

interface Props {
  t: Messages;
}

const { t } = Astro.props;
---

<section id="intrebari" class="set-section set-section--bone">
  <div class="set-section__inner">
    <p class="set-eyebrow">{t.faq.eyebrow}</p>
    <h2 class="set-headline set-faq__title">{t.faq.title}</h2>

    <div class="set-faq__list">
      {
        t.faq.items.map((item) => (
          <details class="set-faq__item">
            <summary class="set-faq__q">
              <span>{item.q}</span>
              <span class="set-faq__icon" aria-hidden="true">+</span>
            </summary>
            <p class="set-faq__a">{item.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .set-faq__title { margin: 8px 0 48px; max-width: 900px; }
  .set-faq__list {
    border-top: 2px solid var(--set-black);
  }
  .set-faq__item {
    border-bottom: 2px solid var(--set-black);
    background: var(--set-white);
  }
  .set-faq__q {
    padding: 24px 28px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    cursor: pointer;
    list-style: none;
    font-size: 22px;
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }
  .set-faq__q::-webkit-details-marker { display: none; }
  .set-faq__icon {
    font-size: 28px;
    line-height: 1;
    color: var(--set-cobalt);
    font-weight: 400;
    transition: transform 0.15s;
  }
  details[open] .set-faq__icon { transform: rotate(45deg); }
  .set-faq__a {
    padding: 0 28px 28px;
    font-size: 17px;
    line-height: 1.55;
    opacity: 0.8;
    margin: 0;
    max-width: 880px;
  }
  @media (max-width: 600px) {
    .set-faq__q { font-size: 18px; padding: 20px; }
    .set-faq__a { padding: 0 20px 20px; }
  }
</style>
