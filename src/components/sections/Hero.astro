---
import Monogram from '../Monogram.astro';
import Button from '../Button.astro';
import type { Messages } from '../../i18n/ro';

interface Props {
  t: Messages;
}

const { t } = Astro.props;
---

<section id="hero" class="set-hero">
  <div class="set-hero__inner">
    <div
      class="set-hero__monogram"
      data-monogram-trigger
      data-hero-sting
      role="button"
      tabindex="0"
      aria-label="SET — Sustainable EdTech Romania"
    >
      {/*
        Sting CSS — joaca o singura data per sesiune (sessionStorage).
        Trei cuvinte (Ready? / Set. / Go!) apar secvential peste monograma
        statica, apoi monograma fade-in la final.
        Fara dependinte: pure CSS keyframes + 10 linii de JS pentru gating.
      */}
      <div class="set-hero__sting" aria-hidden="true">
        <span class="set-hero__sting-word set-hero__sting-word--ready">Ready?</span>
        <span class="set-hero__sting-word set-hero__sting-word--set">Set.</span>
        <span class="set-hero__sting-word set-hero__sting-word--go">Go!</span>
      </div>
      <Monogram size="xl" color="black" />
    </div>

    <p class="set-eyebrow">{t.hero.eyebrow}</p>
    <h1 class="set-display-md set-hero__title">{t.hero.title}</h1>
    <p class="set-lead set-hero__subtitle">{t.hero.subtitle}</p>

    <div class="set-hero__actions">
      <Button href="#contact" variant="default" size="lg">{t.hero.ctaPrimary} →</Button>
      <Button href="#servicii" variant="secondary" size="lg">{t.hero.ctaSecondary}</Button>
    </div>
  </div>
</section>

<style>
  .set-hero {
    background: var(--set-yellow);
    color: var(--set-black);
    border-bottom: 2px solid var(--set-black);
    padding: 80px 32px 96px;
    text-align: center;
  }
  .set-hero__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }
  .set-hero__monogram {
    position: relative;
    margin-bottom: 16px;
    line-height: 0.85;
    cursor: pointer;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }
  .set-hero__monogram:focus-visible {
    outline: 2px dashed var(--set-black);
    outline-offset: 12px;
  }
  /* Mic hover hint (doar desktop, fara mouse-emul pe mobile) */
  @media (hover: hover) {
    .set-hero__monogram:hover :global(.set-monogram > span:nth-child(2)) {
      opacity: 0.7;
      transition: opacity 0.2s;
    }
  }
  .set-hero__title {
    max-width: 900px;
    margin: 0;
  }
  .set-hero__subtitle {
    max-width: 760px;
    margin: 0;
    opacity: 0.75;
  }
  .set-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    margin-top: 16px;
  }

  @media (max-width: 768px) {
    .set-hero { padding: 56px 20px 72px; }
    /* monograma uriasa pe mobile devine prea mare — o restrangem */
    .set-hero__monogram :global(.set-monogram) {
      font-size: 140px !important;
    }
  }
  @media (max-width: 480px) {
    .set-hero { padding: 40px 16px 56px; }
    .set-hero__monogram :global(.set-monogram) {
      font-size: 96px !important;
    }
    .set-hero__actions { flex-direction: column; align-items: stretch; width: 100%; max-width: 320px; }
    .set-hero__actions :global(.set-btn) { justify-content: center; }
  }

  /* ──────────────────────────────────────────────────────────
     Easter egg: tap pe monograma SET → val secvential pe cele 3 litere.
     S sare, apoi E (cu spotlight la full opacity), apoi T.
     One-shot per tap, cu cooldown ~1s.
     ────────────────────────────────────────────────────────── */
  .set-hero__monogram.is-flashing :global(.set-monogram) {
    animation: hero-pulse 800ms ease-in-out;
  }
  .set-hero__monogram.is-flashing :global(.set-monogram > span:nth-child(1)) {
    animation: hero-wave 600ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .set-hero__monogram.is-flashing :global(.set-monogram > span:nth-child(2)) {
    animation: hero-wave-e 600ms cubic-bezier(0.34, 1.56, 0.64, 1) 150ms;
  }
  .set-hero__monogram.is-flashing :global(.set-monogram > span:nth-child(3)) {
    animation: hero-wave 600ms cubic-bezier(0.34, 1.56, 0.64, 1) 300ms;
  }

  @keyframes hero-pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.025); }
  }
  @keyframes hero-wave {
    0%, 100% { transform: translateY(0); }
    40% { transform: translateY(-12px); }
  }
  @keyframes hero-wave-e {
    /* E sare mai sus si capata full opacity in varful sariturii — "spotlight" pe litera estompata */
    0%, 100% { transform: translateY(0); opacity: 0.5; }
    40% { transform: translateY(-20px); opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .set-hero__monogram { cursor: default; }
    .set-hero__monogram.is-flashing :global(.set-monogram),
    .set-hero__monogram.is-flashing :global(.set-monogram > span) {
      animation: none !important;
    }
  }

  /* ──────────────────────────────────────────────────────────
     STING CSS (10 sec total) — Ready? Set. Go!
     Joaca o singura data per sesiune (controlat de JS via sessionStorage).
     Default state: ascuns. Cand parintele .set-hero__monogram primeste
     clasa .is-playing-sting, animatia porneste.

     Timeline:
       0.0–2.0s   Ready?   cobalt, slide-in din stanga
       2.0–4.0s   Set.     vermilion, scale-pop cu overshoot
       4.0–6.5s   Go!      negru bold, drop din sus cu bounce
       6.5–10.0s monograma fade-in (statica devine vizibila)
     ────────────────────────────────────────────────────────── */
  .set-hero__sting {
    position: absolute;
    inset: 0;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .set-hero__sting-word {
    position: absolute;
    font-family: var(--set-font);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 0.95;
    white-space: nowrap;
    opacity: 0;
  }
  .set-hero__sting-word--ready {
    font-size: 200px;
    color: var(--set-cobalt);
  }
  .set-hero__sting-word--set {
    font-size: 220px;
    color: var(--set-vermilion);
  }
  .set-hero__sting-word--go {
    font-size: 260px;
    color: var(--set-black);
  }

  /* Cand sting-ul joaca, monograma statica e ascunsa pana la fade-in din keyframe */
  .set-hero__monogram.is-playing-sting :global(.set-monogram) {
    opacity: 0;
    animation: sting-mono 10s ease forwards;
  }
  .set-hero__monogram.is-playing-sting .set-hero__sting-word--ready {
    animation: sting-ready 10s ease forwards;
  }
  .set-hero__monogram.is-playing-sting .set-hero__sting-word--set {
    animation: sting-set 10s ease forwards;
  }
  .set-hero__monogram.is-playing-sting .set-hero__sting-word--go {
    animation: sting-go 10s ease forwards;
  }

  @keyframes sting-ready {
    /* 0-2 sec din 10 = 0%-20% timeline */
    0%   { opacity: 0; transform: translateX(-100px); }
    6%   { opacity: 1; transform: translateX(0); }
    16%  { opacity: 1; transform: translateX(0); }
    20%  { opacity: 0; transform: translateX(0); }
    100% { opacity: 0; }
  }
  @keyframes sting-set {
    /* 2-4 sec din 10 = 20%-40% */
    0%, 18%  { opacity: 0; transform: scale(0.4); }
    24%      { opacity: 1; transform: scale(1.15); }
    28%, 36% { opacity: 1; transform: scale(1); }
    40%      { opacity: 0; transform: scale(1); }
    100%     { opacity: 0; }
  }
  @keyframes sting-go {
    /* 4-6.5 sec din 10 = 40%-65% */
    0%, 38%  { opacity: 0; transform: translateY(-80px); }
    46%      { opacity: 1; transform: translateY(10px); }
    52%, 60% { opacity: 1; transform: translateY(0); }
    65%      { opacity: 0; transform: translateY(0); }
    100%     { opacity: 0; }
  }
  @keyframes sting-mono {
    /* Monograma fade-in 6.5-10 sec din 10 = 65%-100% */
    0%, 60% { opacity: 0; }
    72%, 100% { opacity: 1; }
  }

  /* Pe mobile, reducem dimensiunile cuvintelor sa nu iasa din ecran */
  @media (max-width: 768px) {
    .set-hero__sting-word--ready { font-size: 88px; }
    .set-hero__sting-word--set { font-size: 96px; }
    .set-hero__sting-word--go { font-size: 116px; }
  }
  @media (max-width: 480px) {
    .set-hero__sting-word--ready { font-size: 64px; }
    .set-hero__sting-word--set { font-size: 72px; }
    .set-hero__sting-word--go { font-size: 88px; }
  }

  /* Reduced motion: sting-ul nu se joaca, monograma statica e vizibila imediat */
  @media (prefers-reduced-motion: reduce) {
    .set-hero__sting { display: none !important; }
    .set-hero__monogram.is-playing-sting :global(.set-monogram) {
      opacity: 1 !important;
      animation: none !important;
    }
  }
</style>

<script>
  // ─────────────────────────────────────────────
  // 1. Sting on first visit per session.
  //    Joaca o data, apoi sessionStorage marks it ca redat.
  //    User-ul poate skip click oriunde pe ecran.
  // ─────────────────────────────────────────────
  const stingTargets = document.querySelectorAll<HTMLElement>('[data-hero-sting]');
  stingTargets.forEach((target) => {
    const STORAGE_KEY = 'set-sting-played';
    const STING_DURATION_MS = 10000;

    const alreadyPlayed = (() => {
      try {
        return sessionStorage.getItem(STORAGE_KEY) === '1';
      } catch {
        return false;
      }
    })();

    const prefersReducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;

    if (alreadyPlayed || prefersReducedMotion) {
      // Skip: nu pornim sting-ul, monograma statica e vizibila by default.
      return;
    }

    // Joaca sting-ul.
    target.classList.add('is-playing-sting');

    const finish = () => {
      target.classList.remove('is-playing-sting');
      try {
        sessionStorage.setItem(STORAGE_KEY, '1');
      } catch {
        /* sessionStorage indisponibil → ignoram */
      }
    };

    const stingTimeoutId = window.setTimeout(finish, STING_DURATION_MS);

    // Skip on click (oricine vrea sa scape direct la continut).
    // Doar pentru sting; NU declanseaza easter egg-ul de tap (acela are propriul guard).
    const skipOnClick = (e: Event) => {
      if (!target.classList.contains('is-playing-sting')) return;
      window.clearTimeout(stingTimeoutId);
      finish();
      e.preventDefault();
      e.stopPropagation();
    };
    target.addEventListener('click', skipOnClick, { capture: true, once: true });
  });

  // ─────────────────────────────────────────────
  // 2. Easter egg: tap pe monograma SET → wave + spotlight pe E.
  // ─────────────────────────────────────────────
  const triggers = document.querySelectorAll<HTMLElement>('[data-monogram-trigger]');
  triggers.forEach((trigger) => {
    let isPlaying = false;

    const play = () => {
      // Daca sting-ul inca joaca, nu activam easter egg-ul (click-ul a skip-uit oricum sting-ul).
      if (trigger.classList.contains('is-playing-sting')) return;
      if (isPlaying) return;
      isPlaying = true;
      trigger.classList.add('is-flashing');
      window.setTimeout(() => {
        trigger.classList.remove('is-flashing');
        isPlaying = false;
      }, 1000);
    };

    trigger.addEventListener('click', play);
    trigger.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        play();
      }
    });
  });
</script>
