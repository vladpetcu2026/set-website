---
import Monogram from '../Monogram.astro';
import Button from '../Button.astro';
import type { Messages } from '../../i18n/ro';

interface Props {
  t: Messages;
}

const { t } = Astro.props;
---

<section id="hero" class="set-hero">
  <div class="set-hero__inner">
    <div
      class="set-hero__monogram"
      data-monogram-trigger
      role="button"
      tabindex="0"
      aria-label="SET — Sustainable EdTech Romania"
    >
      {/*
        Sting video — joaca o data muted la load, se opreste pe ultimul frame
        (care e identic cu monograma statica de mai jos → continuitate vizuala).
        Daca fisierul lipseste, <video> se auto-ascunde si static monogram ramane.
        Vezi public/media/README.md pentru spec.
      */}
      <video
        class="set-hero__video"
        poster="/media/hero-sting-poster.jpg"
        autoplay
        muted
        playsinline
        preload="metadata"
        aria-hidden="true"
        data-hero-video
      >
        <source src="/media/hero-sting.webm" type="video/webm" />
        <source src="/media/hero-sting.mp4" type="video/mp4" />
      </video>
      <Monogram size="xl" color="black" />
    </div>

    <p class="set-eyebrow">{t.hero.eyebrow}</p>
    <h1 class="set-display-md set-hero__title">{t.hero.title}</h1>
    <p class="set-lead set-hero__subtitle">{t.hero.subtitle}</p>

    <div class="set-hero__actions">
      <Button href="#contact" variant="default" size="lg">{t.hero.ctaPrimary} →</Button>
      <Button href="#servicii" variant="secondary" size="lg">{t.hero.ctaSecondary}</Button>
    </div>
  </div>
</section>

<style>
  .set-hero {
    background: var(--set-yellow);
    color: var(--set-black);
    border-bottom: 2px solid var(--set-black);
    padding: 80px 32px 96px;
    text-align: center;
  }
  .set-hero__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }
  .set-hero__monogram {
    position: relative;
    margin-bottom: 16px;
    line-height: 0.85;
    cursor: pointer;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }

  /* Sting video — overlay peste monograma statica.
     Initial display: none (se aprinde via JS doar daca incarca cu succes). */
  .set-hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: none;
    pointer-events: none;
  }
  .set-hero__monogram.has-video .set-hero__video {
    display: block;
  }
  /* Cand video e activ, monograma statica devine doar placeholder de spatiu
     (ramane in markup pentru a11y dar e invizibila) */
  .set-hero__monogram.has-video :global(.set-monogram) {
    visibility: hidden;
  }
  /* Daca user-ul prefera reduced motion, video-ul NU se afiseaza chiar daca a incarcat. */
  @media (prefers-reduced-motion: reduce) {
    .set-hero__video { display: none !important; }
    .set-hero__monogram.has-video :global(.set-monogram) { visibility: visible !important; }
  }
  .set-hero__monogram:focus-visible {
    outline: 2px dashed var(--set-black);
    outline-offset: 12px;
  }
  /* Mic hover hint (doar desktop, fara mouse-emul pe mobile) */
  @media (hover: hover) {
    .set-hero__monogram:hover :global(.set-monogram > span:nth-child(2)) {
      opacity: 0.7;
      transition: opacity 0.2s;
    }
  }
  .set-hero__title {
    max-width: 900px;
    margin: 0;
  }
  .set-hero__subtitle {
    max-width: 760px;
    margin: 0;
    opacity: 0.75;
  }
  .set-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    margin-top: 16px;
  }

  @media (max-width: 768px) {
    .set-hero { padding: 56px 20px 72px; }
    /* monograma uriasa pe mobile devine prea mare — o restrangem */
    .set-hero__monogram :global(.set-monogram) {
      font-size: 140px !important;
    }
  }
  @media (max-width: 480px) {
    .set-hero { padding: 40px 16px 56px; }
    .set-hero__monogram :global(.set-monogram) {
      font-size: 96px !important;
    }
    .set-hero__actions { flex-direction: column; align-items: stretch; width: 100%; max-width: 320px; }
    .set-hero__actions :global(.set-btn) { justify-content: center; }
  }

  /* ──────────────────────────────────────────────────────────
     Easter egg: tap pe monograma SET → val secvential pe cele 3 litere.
     S sare, apoi E (cu spotlight la full opacity), apoi T.
     One-shot per tap, cu cooldown ~1s.
     ────────────────────────────────────────────────────────── */
  .set-hero__monogram.is-flashing :global(.set-monogram) {
    animation: hero-pulse 800ms ease-in-out;
  }
  .set-hero__monogram.is-flashing :global(.set-monogram > span:nth-child(1)) {
    animation: hero-wave 600ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .set-hero__monogram.is-flashing :global(.set-monogram > span:nth-child(2)) {
    animation: hero-wave-e 600ms cubic-bezier(0.34, 1.56, 0.64, 1) 150ms;
  }
  .set-hero__monogram.is-flashing :global(.set-monogram > span:nth-child(3)) {
    animation: hero-wave 600ms cubic-bezier(0.34, 1.56, 0.64, 1) 300ms;
  }

  @keyframes hero-pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.025); }
  }
  @keyframes hero-wave {
    0%, 100% { transform: translateY(0); }
    40% { transform: translateY(-12px); }
  }
  @keyframes hero-wave-e {
    /* E sare mai sus si capata full opacity in varful sariturii — "spotlight" pe litera estompata */
    0%, 100% { transform: translateY(0); opacity: 0.5; }
    40% { transform: translateY(-20px); opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .set-hero__monogram { cursor: default; }
    .set-hero__monogram.is-flashing :global(.set-monogram),
    .set-hero__monogram.is-flashing :global(.set-monogram > span) {
      animation: none !important;
    }
  }
</style>

<script>
  // ─────────────────────────────────────────────
  // 1. Easter egg: tap pe monograma SET → wave + spotlight pe E.
  // ─────────────────────────────────────────────
  const triggers = document.querySelectorAll<HTMLElement>('[data-monogram-trigger]');
  triggers.forEach((trigger) => {
    let isPlaying = false;

    const play = () => {
      if (isPlaying) return;
      isPlaying = true;
      trigger.classList.add('is-flashing');
      window.setTimeout(() => {
        trigger.classList.remove('is-flashing');
        isPlaying = false;
      }, 1000);
    };

    trigger.addEventListener('click', play);
    trigger.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        play();
      }
    });
  });

  // ─────────────────────────────────────────────
  // 2. Hero sting video: activeaza overlay-ul doar daca incarcarea reuseste.
  //    Daca fisierul /media/hero-sting.mp4 lipseste, <video> da error si
  //    ramane ascuns — monograma statica continua sa fie vizibila.
  // ─────────────────────────────────────────────
  const videos = document.querySelectorAll<HTMLVideoElement>('[data-hero-video]');
  videos.forEach((video) => {
    const parent = video.closest<HTMLElement>('.set-hero__monogram');
    if (!parent) return;

    // Verifica prefers-reduced-motion: daca user-ul prefera reducere, nu activam video.
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) {
      // Suspendam complet video-ul (nu downloadam, nu activam).
      video.remove();
      return;
    }

    const enable = () => parent.classList.add('has-video');
    const disable = () => parent.classList.remove('has-video');

    // Daca a inceput sa joace, marcheaza overlay-ul activ.
    video.addEventListener('playing', enable, { once: true });
    // Pe loadeddata (primul frame disponibil), aprinde overlay-ul preventiv.
    video.addEventListener('loadeddata', enable, { once: true });
    // Daca incarcarea esueaza (fisier lipsa / 404 / format), ascundem.
    video.addEventListener('error', disable);
    // La fel pentru source-uri individuale.
    video.querySelectorAll('source').forEach((s) => s.addEventListener('error', () => {
      // Doar daca TOATE source-urile esueaza, ascundem; browser-ul incearca alternativ.
      if (video.networkState === HTMLMediaElement.NETWORK_NO_SOURCE) disable();
    }));
  });
</script>
