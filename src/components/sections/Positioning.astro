---
import Tag from '../Tag.astro';
import type { Messages } from '../../i18n/ro';

interface Props {
  t: Messages;
}

const { t } = Astro.props;
---

<section class="set-section set-section--bone">
  <div class="set-section__inner">
    <p class="set-eyebrow">{t.positioning.eyebrow}</p>
    <h2 class="set-headline set-pos__title">{t.positioning.title}</h2>

    <div class="set-pos__grid">
      <div class="set-pos__col set-pos__col--no">
        <Tag variant="danger">{t.positioning.no.tag}</Tag>
        <ul>
          {t.positioning.no.items.map((it) => <li>{it}</li>)}
        </ul>
      </div>

      <div class="set-pos__col set-pos__col--yes">
        <Tag variant="black">{t.positioning.yes.tag}</Tag>
        <ul>
          {t.positioning.yes.items.map((it) => <li>{it}</li>)}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .set-pos__title { margin: 8px 0 56px; max-width: 900px; }
  .set-pos__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .set-pos__col {
    padding: 40px;
    border: 2px solid var(--set-black);
    background: var(--set-white);
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .set-pos__col--yes { background: var(--set-yellow); }
  .set-pos__col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .set-pos__col li {
    font-size: 22px;
    font-weight: 500;
    line-height: 1.3;
  }
  @media (max-width: 768px) {
    .set-pos__grid { grid-template-columns: 1fr; }
    .set-pos__col { padding: 28px 24px; }
    .set-pos__col li { font-size: 18px; line-height: 1.35; }
  }
  @media (max-width: 480px) {
    .set-pos__col { padding: 24px 20px; gap: 20px; }
    .set-pos__col li { font-size: 16px; }
  }
</style>
