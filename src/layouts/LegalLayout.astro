---
/**
 * LegalLayout — sablon pentru paginile legale (Termeni / Privacy / Cookies).
 * Foloseste acelasi Nav + Footer ca pe home, dar continutul e un wrapper de citit.
 */
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import type { Messages } from '../i18n/ro';

interface Props {
  title: string;
  description: string;
  lang: 'ro' | 'en';
  lastUpdated: string;
  t: Messages;
}

const { title, description, lang, lastUpdated, t } = Astro.props;
const updatedLabel = lang === 'ro' ? 'Ultima actualizare' : 'Last updated';
---

<Base title={title} description={description} lang={lang}>
  <Nav t={t} />

  <main class="set-legal">
    <div class="set-legal__inner">
      <p class="set-caption set-legal__updated">{updatedLabel}: {lastUpdated}</p>
      <slot />
    </div>
  </main>

  <Footer t={t} />
</Base>

<style is:global>
  .set-legal {
    padding: 64px 32px 96px;
    background: var(--set-white);
    color: var(--set-black);
  }
  .set-legal__inner {
    max-width: 820px;
    margin: 0 auto;
  }
  .set-legal__updated {
    opacity: 0.55;
    margin: 0 0 16px;
  }
  .set-legal h1 {
    font-size: 56px;
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-weight: 600;
    margin: 0 0 16px;
  }
  .set-legal h2 {
    font-size: 28px;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 48px 0 12px;
  }
  .set-legal h3 {
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    margin: 24px 0 8px;
  }
  .set-legal p,
  .set-legal li {
    font-size: 17px;
    line-height: 1.65;
  }
  .set-legal p { margin: 12px 0; }
  .set-legal ul,
  .set-legal ol {
    padding-left: 24px;
    margin: 12px 0;
  }
  .set-legal li { margin: 6px 0; }
  .set-legal a {
    color: var(--set-cobalt);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .set-legal a:hover { opacity: 0.8; }
  .set-legal table {
    width: 100%;
    border-collapse: collapse;
    margin: 16px 0;
    font-size: 15px;
  }
  .set-legal th,
  .set-legal td {
    border: 1.5px solid var(--set-black);
    padding: 10px 12px;
    text-align: left;
    vertical-align: top;
  }
  .set-legal th {
    background: var(--set-bone);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    font-size: 13px;
  }
  .set-legal hr {
    border: none;
    border-top: 1.5px solid var(--set-line);
    margin: 48px 0;
  }
  .set-legal strong { font-weight: 600; }

  @media (max-width: 600px) {
    .set-legal h1 { font-size: 36px; }
    .set-legal h2 { font-size: 22px; }
    .set-legal { padding: 40px 20px 64px; }
  }
</style>
